{
  "comments": {
    "blockComment": ["<!--", "-->"]
  },
  "brackets": [
    ["<%", "%>"],
    ["<", ">"],
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "<%", "close": "%>" },
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "|", "close": "|", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["<%", "%>"],
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*<%/?(?:If|Switch|OnArgument|OnEntity|OnField)\\b",
      "end": "^\\s*<%/(?:If|Switch|OnArgument|OnEntity|OnField)%>"
    }
  }
}
